{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/execution/layout,_N_T_/execution/page,_N_T_/execution"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/execution/__PAGE__",
    "/execution",
    "/_index",
    "/_head"
  ]
}